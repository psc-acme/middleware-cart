{
    "name": "psc-acme/middleware-cart",
    "description": "Package middleware-cart for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\MiddlewareCart\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "vlucas/phpdotenv": "^5.0",
        "brick/date-time": "^0.7.1",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.0",
        "vimeo/psalm": "^5.0",
        "rector/rector": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}